<Window x:Class="云端管理.EditServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑服务器配置" Height="620" Width="450" 
        WindowStartupLocation="CenterOwner" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#111"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#111"/>
        </Style>
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#88FFFFFF"/>
            <Setter Property="BorderBrush" Value="#33000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="6" Margin="3" Background="Transparent" Cursor="Hand">
                            <TextBlock x:Name="txt" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888" FontWeight="Bold" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="txt" Property="Foreground" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Effect>
        <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.15" Color="Black"/>
    </Window.Effect>

    <Border CornerRadius="20" Background="#E6FFFFFF" BorderBrush="White" BorderThickness="1.5" Margin="15">
        <Grid Margin="30,20,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="服务器配置" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
            <Button HorizontalAlignment="Right" Width="30" Height="30" Foreground="#888" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Cancel_Click">
                <TextBlock Text="✕" FontSize="16" FontWeight="Bold" Margin="0" Padding="0"/>
            </Button>

            <StackPanel Grid.Row="1" Margin="0,15,0,0">
                <TextBlock Text="服务器名称 (别名)"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="NameInput"/>
                </Border>

                <TextBlock Text="主机 IP 地址"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="HostInput"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="端口"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="PortInput" Text="22"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="用户名"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="UserInput"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <TextBlock Text="认证方式"/>
                <Border CornerRadius="8" Background="#E0E0E0" Height="42" Margin="0,0,0,20">
                    <UniformGrid Columns="2">
                        <RadioButton x:Name="RadioPwd" Content="密码登录" Style="{StaticResource SegmentButton}" IsChecked="True" Checked="AuthType_Changed"/>
                        <RadioButton x:Name="RadioKey" Content="私钥登录" Style="{StaticResource SegmentButton}" Checked="AuthType_Changed"/>
                    </UniformGrid>
                </Border>

                <TextBlock x:Name="SecretLabel" Text="SSH 密码"/>
                <Grid x:Name="PasswordArea">
                    <Border Style="{StaticResource InputBorder}">
                        <PasswordBox x:Name="PasswordInput"/>
                    </Border>
                </Grid>

                <Grid x:Name="KeyArea" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource InputBorder}" Grid.Column="0" Margin="0,0,10,20">
                        <TextBox x:Name="KeyPathDisplay" IsReadOnly="True" Text="未选择密钥" Foreground="#888"/>
                    </Border>
                    <Button Content="   选 择   " Grid.Column="1" Margin="0,0,0,20" Padding="15,0" Background="#D0D0D0" BorderThickness="0" Cursor="Hand" Click="SelectKey_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <UniformGrid Columns="2" Margin="0,15,0,0">
                    <Button Content="取 消" Margin="0,0,10,0" Height="45" FontSize="16" Foreground="#555" Background="#E0E0E0" Click="Cancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="保 存" Height="45" FontSize="16" FontWeight="Bold" Foreground="White" Background="#1A1A1A" Click="Save_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>