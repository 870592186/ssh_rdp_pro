<Window x:Class="云端管理.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="安全解锁" Height="350" Width="420" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="17.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Window.Effect>
        <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.15" Color="Black"/>
    </Window.Effect>
    

    <Border CornerRadius="20" Background="#E6FFFFFF" BorderBrush="White" BorderThickness="1.5" Margin="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="SSH Manager" Foreground="#333" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="☁️" Click="CloudSettings_Click" Style="{StaticResource IconBtnStyle}" ToolTip="云同步设置"/>
                <Button Content="✕" Click="Close_Click" Style="{StaticResource IconBtnStyle}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="35,10,35,30" VerticalAlignment="Center">
                <TextBlock x:Name="StatusLabel" Text="请输入主密码解锁:" Foreground="#444" FontSize="16" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Border CornerRadius="8" Background="#88FFFFFF" BorderBrush="#33000000" BorderThickness="1" Margin="0,0,0,30">
                    <PasswordBox x:Name="PasswordInput" Padding="10,8" FontSize="18" 
                                 Background="Transparent" Foreground="#111" BorderThickness="0"
                                 KeyDown="PasswordInput_KeyDown"/>
                </Border>

                <Button x:Name="LoginBtn" Content="解 锁" Height="45" FontSize="16" FontWeight="Bold" Foreground="White" 
                        Click="Login_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="#1A1A1A" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#888"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>