<Window x:Class="云端管理.CloudSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="云同步配置" Height="400" Width="400" WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">
    <Border CornerRadius="20" Background="#E6FFFFFF" BorderBrush="White" BorderThickness="1.5" Margin="15">
        <StackPanel Margin="25">
            <TextBlock Text="WebDAV 云同步配置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="服务器地址 (如: https://dav.jianguoyun.com/dav/)" FontSize="12" Foreground="#666"/>
            <TextBox x:Name="UrlInput" Margin="0,5,0,15" Padding="8"/>

            <TextBlock Text="账号" FontSize="12" Foreground="#666"/>
            <TextBox x:Name="UserInput" Margin="0,5,0,15" Padding="8"/>

            <TextBlock Text="应用授权码/密码" FontSize="12" Foreground="#666"/>
            <PasswordBox x:Name="PwdInput" Margin="0,5,0,25" Padding="8"/>

            <UniformGrid Columns="2">
                <Button Content="取 消" Click="Cancel_Click" Margin="0,0,5,0" Height="40"/>
                <Button Content="验证并保存" Click="Save_Click" Background="#1A1A1A" Foreground="White" Height="40"/>
            </UniformGrid>
        </StackPanel>
    </Border>
    <Window.Effect>
        <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.15" Color="Black"/>
    </Window.Effect>


</Window>